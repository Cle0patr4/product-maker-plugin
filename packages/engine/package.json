{
  "name": "@spicy/product-maker",
  "version": "2.0.0-alpha.0",
  "description": "Autonomous multi-agent product maker engine (v2). Builds on Claude Managed Agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "product-maker": "./bin/product-maker.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "tsc -b --clean && rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "anthropic",
    "managed-agents",
    "autonomous",
    "ai",
    "product-maker"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
